{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provoware.local/multimodultool2026/module-manifest.schema.json",
  "title": "MULTIMODULTOOL2026 Module Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "type",
    "description",
    "entry",
    "permissions",
    "storage",
    "validation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 42
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "overview",
        "calendar",
        "notes",
        "tasks",
        "projectboard",
        "stats",
        "quicktext",
        "editor",
        "code",
        "settings",
        "timer",
        "bookmarks",
        "activity",
        "modulebuilder",
        "mother",
        "registry",
        "debugging",
        "custom"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 240
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["html", "css", "js"],
      "properties": {
        "html": { "type": ["string", "null"], "pattern": "^module\\.html$" },
        "css": { "type": ["string", "null"], "pattern": "^module\\.css$" },
        "js": { "type": ["string", "null"], "pattern": "^module\\.js$" }
      }
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["local-storage", "file-export", "file-import", "timer", "none"]
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "backupRequired"],
      "properties": {
        "scope": { "type": "string", "enum": ["module", "workspace", "none"] },
        "backupRequired": { "type": "boolean" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxInputBytes", "allowedFileExtensions"],
      "properties": {
        "maxInputBytes": { "type": "integer", "minimum": 0, "maximum": 8000000 },
        "allowedFileExtensions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^\\.[a-z0-9]+$" }
        }
      }
    }
  }
}
