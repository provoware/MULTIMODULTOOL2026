{
  "id": "provoware-genretool-pro",
  "name": "Provoware GenreTool Pro",
  "version": "1.0.0",
  "type": "custom",
  "description": "Songs-Untermodul für Genre-, Stimmungs-, Stil-, Effekt-, Themen- und Besonderheiten-Kombinationen.",
  "entry": {
    "html": null,
    "css": null,
    "js": null
  },
  "permissions": [
    "local-storage",
    "file-export",
    "file-import"
  ],
  "storage": {
    "scope": "module",
    "backupRequired": true
  },
  "validation": {
    "maxInputBytes": 8000000,
    "allowedFileExtensions": [
      ".json",
      ".txt",
      ".csv"
    ]
  }
}
