{
  "id": "provoware-genretool-pro",
  "name": "Provoware GenreTool Pro",
  "version": "1.1.0",
  "type": "custom",
  "description": "Songs-Untermodul zum Verwalten und Kombinieren von Genres, Stimmungen, Stilen, Effekten, Themen und Besonderheiten.",
  "entry": {
    "html": "module.html",
    "css": "module.css",
    "js": "module.js"
  },
  "permissions": [
    "local-storage",
    "file-export",
    "file-import"
  ],
  "storage": {
    "scope": "module",
    "backupRequired": true
  },
  "validation": {
    "maxInputBytes": 8000000,
    "allowedFileExtensions": [
      ".json",
      ".txt",
      ".csv"
    ]
  }
}
